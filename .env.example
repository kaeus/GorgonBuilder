# Copy to .env.local and fill in from Firebase console.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Only set in the GH Actions workflow (e.g. "/GorgonBuilder/").
# VITE_BASE=/GorgonBuilder/

# Pin the CDN version instead of fetching fileversion.txt.
# VITE_CDN_VERSION=466

# Cloudflare Worker that proxies gorgonexplorer.com/api/build/<id>.
# See worker/README.md for deploy steps. Leave blank to fall back to the
# Vite dev proxy + allorigins.win path.
# VITE_GE_PROXY=https://gorgon-proxy.<your-subdomain>.workers.dev
